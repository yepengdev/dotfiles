// ────────────── Window & Layer Rules ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Window-Rules

// Default rule: no rounded corners, blur background
window-rule {
    geometry-corner-radius 10
    clip-to-geometry true
    background-effect {
        xray true
        blur true
        noise 0.05
        saturation 1.5
    }
}

// Noctalia wallpaper: render behind all windows
layer-rule {
    match namespace="^noctalia-wallpaper*"
    place-within-backdrop true
}

// Inactive windows: slightly dimmed
window-rule {
    match is-active=false
    opacity 0.9
}

// Image viewer (Loupe): open floating by default
window-rule {
    match app-id="^org.gnome.Loupe"
    open-floating true
}

// Emacs floating window (for transient popups)
window-rule {
    match app-id="emacs" title="emacs-float"
    open-floating true
}

// Emacs main window: workspace 3, maximized, blur background
window-rule {
    match app-id="emacs"
    //open-on-workspace "3"     // Workspace layout: 1=term, 2=browser, 3=code
    opacity 0.85
    open-maximized true
    background-effect {
        xray true
        blur true
    }
}

// Zathura (PDF reader): no rounded corners
window-rule {
    match app-id="^org.pwmt.zathura$"
    open-maximized true
    geometry-corner-radius 0
    opacity 0.95
}

// Blur + rounded corners for popup menus (GTK/Qt apps)
window-rule {
    match app-id="^nautilus$"
    match app-id="^org.gnome.Nautilus$"
    match app-id="^thunar$"
    popups {
        geometry-corner-radius 12
        background-effect {
            blur true
        }
    }
}

// Fcitx5 candidate window: no background border
// 为 fcitx5 候选窗口设置规则
// Without this, the IME popup draws an unwanted opaque border.
window-rule {
    match app-id="fcitx5"
    draw-border-with-background true
    background-effect {
        blur true
    }
}
window-rule {
    match app-id="^Alacritty$"
    open-maximized true

    background-effect {
        blur true
    }
}

// Enable blur behind the fuzzel launcher.
layer-rule {
    match namespace="^launcher$"

    background-effect {
        blur true
    }
}

