// ────────────── Input Configuration ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input
//
// Commented-out lines below are alternative options kept for reference.
// Uncomment and adjust as needed — they do not take effect while commented.

input {
    keyboard {
        xkb {
            layout "us"
            options "compose:ralt"   // Right Alt as Compose key (for accented characters)
        }
        repeat-delay 300             // ms before key repeat starts
        repeat-rate 60               // chars/sec while held
        // track-layout "global"     // Alternative: track layout per window instead of globally
        numlock
    }

    touchpad {
        tap                          // Tap-to-click
        natural-scroll               // macOS-style scroll direction
        dwt                          // Disable while typing
    }

    trackpoint {
        // Uncomment to disable: // off
        natural-scroll
        // Alternative trackpoint configurations (uncomment to try):
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // scroll-button-lock
        // left-handed
        middle-emulation             // Simultaneous left+right = middle click
    }

    focus-follows-mouse max-scroll-amount="0%"  // Auto-focus under cursor; 0% prevents edge-scroll
    workspace-auto-back-and-forth               // Toggle between last two workspaces
    warp-mouse-to-focus                         // Move cursor to focused window on keyboard navigation
}
