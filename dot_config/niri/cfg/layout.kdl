// ────────────── Layout & Appearance ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Layout

layout {
    gaps 16                       // px between windows / screen edges
    center-focused-column "never" // Don't auto-center the active column

    background-color "transparent"

    default-column-width { proportion 0.5; }  // New windows open at half width

    preset-column-widths {        // Cycle targets for MOD+R / MOD+SHIFT+R
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    preset-window-heights {       // Cycle targets for MOD+SHIFT+CTRL+R
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    border {
        width 2
        active-color "#80c8ff"
        inactive-color "#404040"
    }

    focus-ring {
        width 4
        active-gradient from="#80c8ff" to="#bbddff" angle=45
    }

    insert-hint {
        color "#80c8ff80"
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#00000070"
    }
}
