  // System monitoring
  "cpu": {
    "format": "пӢӣ {usage}%",
    "format-alt": "пӢӣ {usage}% ({load})",
    "tooltip-format": "CPU: {usage}%\nLoad: {load}",
    "interval": 2
  },

  "memory": {
    "format": "пғү {}%",
    "format-alt": "пғү {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "еҶ…еӯҳ: {used:0.1f}G / {total:0.1f}G ({percentage}%)",
    "interval": 2
  },

  "temperature": {
    "thermal-zone": 0,
    "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
    "format": "пӢү {temperatureC}В°C",
    "critical-threshold": 80,
    "format-critical": "пӢҮ {temperatureC}В°C",
    "tooltip-format": "жё©еәҰ: {temperatureC}В°C",
    "interval": 2
  },

  //"disk": {
  //  "format": "пӮ  {percentage_used}%",
  //  "path": "/",
  //  "interval": 30
  //},

  // Power management
  //"power-profiles-daemon": {
  //  "format": "{icon}",
  //  "format-icons": {
  //    "performance": "пҒӯ",
  //    "balanced": "пүҺ",
  //    "power-saver": "пҒ¬"
  //  },
  //  "tooltip-format": "Power Profile: {profile}"
  //},

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пҮҰ {capacity}%",
    "format-plugged": "пҮҰ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["пү„ ", "пүғ ", "пүӮ ", "пүҒ ", "пүҖ "],
    "interval": 5
  },

  // Audio
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "пҖҰ Muted",
    "format-icons": ["пҖҰ", "пҖ§", "пҖЁ"],
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  // Network
  "network": {
    "format-wifi": "пҮ« {essid}",
    "format-ethernet": "пңҖ {ifname}",
    "format-disconnected": "пңҒ ж–ӯејҖ",
    "tooltip-format": "{ifname}: {ipaddr}\nдҝЎеҸ·ејәеәҰ: {signalStrength}%",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
    "interval": 5
  },

  // Network speed
  "custom/net-speed": {
    "exec": "~/.config/waybar/net-speed.sh",
    "interval": 1,
    "tooltip": false
  },

  // Weather
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "interval": 600,
    "tooltip": true,
    "on-click": "xdg-open 'https://wttr.in'"
  },

  // Clock
  "clock": {
    "format": "пҖ— {:%H:%M}",
    "format-alt": "пҒі {:%Y-%m-%d %H:%M}",
    "tooltip-format": "<big>{:%Yе№ҙ%mжңҲ%dж—Ҙ}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "swaymsg exec 'gnome-calendar' || swaymsg exec 'calcurse'",
    "interval": 30
  },

  // System tray
  "tray": {
    "icon-size": 12,
    "spacing": 4
  },

  // Power menu
  "custom/power": {
    "format": "'\u202f'вҸ»",
    "on-click": "wlogout",
    "tooltip": false
  },

  // Pomodoro timer
  "custom/pomodoro": {
    "exec": "~/.config/waybar/scripts/pomodoro.sh status",
    "interval": 1,
    "on-click": "~/.config/waybar/scripts/pomodoro.sh toggle",
    "on-click-middle": "~/.config/waybar/scripts/pomodoro.sh skip",
    "on-click-right": "~/.config/waybar/scripts/pomodoro.sh reset",
    "tooltip": true
  },

  // Bluetooth
  "bluetooth": {
    "format": "пҠ”",
    "format-disabled": "у°ӮІ",
    "format-connected": "пҠ“ {device_alias}",
    "format-connected-battery": "пҠ“ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "пҠ” {controller_alias}\t{status}",
    "tooltip-format-connected": "пҠ” {controller_alias}\t{status}\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager",
    "on-click-right": "bluetoothctl power toggle"
  }
}


